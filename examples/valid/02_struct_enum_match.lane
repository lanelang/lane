module Examples.Valid02

import Ops.*

pub struct Point {
  x : Int
  y : Int
}

pub enum Option[A] {
  none()
  some(A)
}

pub fn unwrap_or(value : Option[Int], fallback : Int) -> Int {
  match value {
    none() => fallback
    some(x) => x
  }
}

pub fn sum_point(point : Point) -> Int {
  match point {
    Point::{
      x,
      y
    } => x + y
  }
}

pub let origin : Point = Point::{
  x: 0,
  y: 0
}

pub let chosen : Option[Int] = some(1)
