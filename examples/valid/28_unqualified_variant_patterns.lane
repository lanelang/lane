module Examples.Valid.UnqualifiedVariantPatterns

import Basic.Ops.*

import Basic.Io.{println}

enum Left {
  same(Int)
}

enum Right {
  same(Bool)
}

fn read_left(value : Left) -> Int {
  match value {
    same(x) => x
  }
}

fn read_right(value : Right) -> Int {
  match value {
    same(_) => 1
  }
}

pub let left_payload : Int = read_left(Left::same(42))

pub fn answer() -> Unit ! Io {
  if left_payload == 42 && read_right(Right::same(true)) == 1 {
    println("left=42 right=1")
  } else {
    println("bad:left=42 right=1")
  }
}
