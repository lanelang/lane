module Examples.Valid.HandleBlockSubject

import Basic.Io.{ println }
import Basic.Trait.Ops.*

effect Console {
  read() -> Int
}

pub let handled_value : Int = {
  handle {
    let base : Int = 40
    base + Console::read!()
  } with {
    Console::read(resume) => resume(2)
  } final value {
    value
  }
}

pub fn answer() -> Unit ! Io {
  if handled_value == 42 {
    println("42")
  } else {
    println("bad:42")
  }
}
