// Valid: higher-kinded alias header parameters must carry explicit kind
// annotations.

module Examples.Valid18

import Stdlib.Ops.*

import Stdlib.Io.{Io, Write}

pub struct Box[A] {
  value : A
}

pub type ApplyInt[F : [Type] -> Type] = F[Int]

pub fn get(box : ApplyInt[Box]) -> Int {
  box.value
}

pub let higher_kind_value : Int = get(
  Box::{
    value: 42
  }
)

pub fn answer() -> Unit ! Io {
  if higher_kind_value == 42 {
    Write::println!("42")
  } else {
    Write::println!("bad:42")
  }
}
