module Examples.Valid.NestedPatternExhaustiveness

pub enum Option[A] {
  none()
  some(A)
}

pub struct Box[A] {
  value : A
}

pub fn flatten(value : Option[Option[Int]]) -> Int {
  match value {
    none() => 0
    some(none()) => 1
    some(some(x)) => x
  }
}

pub fn boxed(value : Box[Option[Int]]) -> Int {
  match value {
    Box::{
      value: none()
    } => 0
    Box::{
      value: some(x)
    } => x
  }
}

pub let answer : Int = flatten(some(some(42)))
