module Examples.Valid.ElseIfChain

import Basic.Ops.*

import Basic.Io.{println}

pub fn choose(first : Bool, second : Bool) -> Int {
  if first {
    1
  } else if second {
    2
  } else {
    3
  }
}

pub let first : Int = choose(true, false)

pub let second : Int = choose(false, true)

pub let fallback : Int = choose(false, false)

pub fn answer() -> Unit ! Io {
  if first == 1 && second == 2 && fallback == 3 {
    println("1,2,3")
  } else {
    println("bad:1,2,3")
  }
}
