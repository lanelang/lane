module Examples.Valid14

import Basic.Io.{println}

pub enum Packed {
  hide[T](T)
}

pub fn repack(p : Packed) -> Packed {
  match p {
    Packed::hide[T](value) => Packed::hide[T](value)
  }
}

pub let packed_int : Packed = Packed::hide[Int](42)

pub let repacked_int : Packed = repack(packed_int)

pub fn answer() -> Unit ! Io {
  println("existential enum packed")
}
