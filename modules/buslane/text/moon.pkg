import {
  "Milky2018/buslane",
  "moonbit-community/prettyprinter",
  "moonbitlang/core/encoding/utf8",
  "moonbitlang/core/list",
  "moonbitlang/core/string",
}

rule(
  name: "moonyacc",
  command: "moon runwasm moonbitlang/yacc@0.7.17 --no-comments $input -o $output",
)

dev_build(
  rule: "moonyacc",
  input: "parser.mbty",
  output: "generated_parser.mbt",
)
