import {
  "Milky2018/lanec/basic",
  "Milky2018/lanec/diagnostic" @compiler_diag,
  "Milky2018/lanec/driver",
  "Milky2018/lanec/module/frontend" @module_frontend,
  "moonbitlang/core/encoding/utf8",
  "moonbitlang/core/json",
}

supported_targets = "wasm"

options(
  link: {
    "wasm": {
      "exports": [ "transfer_ptr", "transfer_capacity", "entries", "explore" ],
      "export-memory-name": "memory",
      "heap-start-address": 16777216,
    },
  },
)
