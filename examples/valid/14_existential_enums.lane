module Examples.Valid14

import Basic.Ops.*

import Basic.Io.{Io, Write}

pub enum Packed {
  hide[T](T)
}

pub fn repack(p : Packed) -> Packed {
  match p {
    Packed::hide[T](value) => Packed::hide[T](value)
  }
}

pub let packed_int : Packed = Packed::hide[Int](builtin("%external_int"))

pub let repacked_int : Packed = repack(packed_int)

pub fn answer() -> Unit ! Io {
  Write::println!("existential enum packed")
}
