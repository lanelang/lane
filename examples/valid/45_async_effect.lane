module Examples.Valid.AsyncEffect

import Basic.Io.{Io, Write}

import Basic.Ops.*

effect Async[E : Effect] {
  suspend[A](((A) -> Unit ! E) -> Unit ! E) -> A
}

effect Schedule {
  enqueue(Step) -> Unit
}

enum Step {
  done(Int)
  waiting[A](((A) -> Unit ! Schedule) -> Unit ! Schedule, (A) -> Step)
}

fn[A] ready(value : A) -> A ! Async[Schedule] {
  suspend![A](
    fn (resume) {
      resume(value)
    }
  )
}

fn run_task(task : () -> Int ! Async[Schedule]) -> Step {
  handle task() with {
    suspend[A](register, resume) => waiting[A](
      register,
      fn (value) {
        resume(value)
      }
    )
  } final value {
    done(value)
  }
}

fn[A] run_registration(
  register : ((A) -> Unit ! Schedule) -> Unit ! Schedule,
  resume : (A) -> Step
) -> Step {
  handle register(
    fn (value) {
      let next : Step = resume(value)
      enqueue!(next)
    }
  ) with {
    enqueue(next, _continue) => next
  } final _value {
    done(0)
  }
}

fn run_loop(step : Step) -> Int {
  match step {
    done(value) => value
    waiting[A](register, resume) => run_loop(run_registration[A](register, resume))
  }
}

fn program() -> Int ! Async[Schedule] {
  let first = ready(20)
  let flag = ready(true)
  if flag {
    first + ready(22)
  } else {
    0
  }
}

pub let async_result : Int = run_loop(run_task(program))

pub fn answer() -> Unit ! Io {
  if async_result == 42 {
    Write::println!("42")
  } else {
    Write::println!("bad:42")
  }
}
