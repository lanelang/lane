module Examples.Valid.ModuleQualifiedTypeAccess

import Basic.Ops.*

import Basic.Io.{Io, Write}

import Basic.Builtins

let add_ops : Basic.Ops.Add[Int] = Basic.Ops.Add::{ add: Basic.Builtins.int_add }

pub let sum_value : Int = add_ops.add(20, 22)

pub fn answer() -> Unit ! Io {
  if sum_value == 42 {
    Write::println!("42")
  } else {
    Write::println!("bad:42")
  }
}
