module Examples.Valid.DoubleOperations

import Basic.Io.{Io, Write}

import Basic.Ops.*

pub fn answer() -> Unit ! Io {
  if !(1.5 + 2.5 == 4.0) {
    Write::println!("double add or equal failed")
  } else if !(6.0 / 2.0 == 3.0) {
    Write::println!("double div failed")
  } else if !(5.0 - 1.0 == 4.0) {
    Write::println!("double sub failed")
  } else if !(2.0 * 3.0 == 6.0) {
    Write::println!("double mul failed")
  } else if !(-1.0 < 0.0) {
    Write::println!("double neg or less failed")
  } else if !(2.0 >= 2.0) {
    Write::println!("double greater_eq failed")
  } else {
    Write::println!("double operations ok")
  }
}
