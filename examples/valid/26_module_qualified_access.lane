module Examples.Valid.ModuleQualifiedAccess

import Basic.Ops.*

import Basic.Io.{Io, Write}

import Basic.Builtins

pub let sum_value : Int = Basic.Builtins.int_add(20, 22)

pub fn answer() -> Unit ! Io {
  if sum_value == 42 {
    Write::println!("42")
  } else {
    Write::println!("bad:42")
  }
}
