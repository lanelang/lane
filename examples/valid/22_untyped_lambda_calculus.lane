module Examples.Valid22

import Ops.*

pub enum Option[A] {
  none()
  some(A)
}

pub enum Term {
  var(Int)
  lam(Term)
  app(Term, Term)
}

pub fn shift_from(cutoff : Int, delta : Int, term : Term) -> Term {
  match term {
    ::var(index) =>
      if index < cutoff {
        var(index)
      } else {
        var(index + delta)
      }
    ::lam(body) => lam(shift_from(cutoff + 1, delta, body))
    ::app(function, argument) => app(
      shift_from(cutoff, delta, function),
      shift_from(cutoff, delta, argument)
    )
  }
}

pub fn shift(delta : Int, term : Term) -> Term {
  shift_from(0, delta, term)
}

pub fn subst(index : Int, replacement : Term, term : Term) -> Term {
  match term {
    ::var(variable) =>
      if variable == index {
        replacement
      } else {
        var(variable)
      }
    ::lam(body) => lam(subst(index + 1, shift(1, replacement), body))
    ::app(function, argument) => app(
      subst(index, replacement, function),
      subst(index, replacement, argument)
    )
  }
}

pub fn beta(body : Term, argument : Term) -> Term {
  shift(-1, subst(0, shift(1, argument), body))
}

pub fn step(term : Term) -> Option[Term] {
  match term {
    ::var(_) => Option::none()
    ::lam(body) =>
      match step(body) {
        ::none() => Option::none()
        ::some(next) => some(lam(next))
      }
    ::app(function, argument) =>
      match function {
        ::lam(body) => some(beta(body, argument))
        _ =>
          match step(function) {
            ::some(next_function) => some(app(next_function, argument))
            ::none() =>
              match step(argument) {
                ::none() => Option::none()
                ::some(next_argument) => some(app(function, next_argument))
              }
          }
      }
  }
}

pub fn normalize(limit : Int, term : Term) -> Term {
  if limit == 0 {
    term
  } else {
    match step(term) {
      ::none() => term
      ::some(next) => normalize(limit - 1, next)
    }
  }
}

pub fn term_size(term : Term) -> Int {
  match term {
    ::var(_) => 1
    ::lam(body) => 1 + term_size(body)
    ::app(function, argument) => 1 + term_size(function) + term_size(argument)
  }
}

pub fn is_identity(term : Term) -> Bool {
  match term {
    ::lam(body) =>
      match body {
        ::var(index) => index == 0
        _ => false
      }
    _ => false
  }
}

pub let identity : Term = lam(var(0))

pub let applied_identity : Term = app(identity, identity)

pub let normal_identity : Term = normalize(8, applied_identity)

pub let answer : Int = if is_identity(normal_identity) {
  40 + term_size(normal_identity)
} else {
  0
}
