module Examples.Valid05

import Stdlib.Io.{Io, Write}

import Stdlib.Ops.*

pub fn custom_add(a : Int, b : Int) -> Int {
  a
}

pub offer custom_add_ops : Add[Int] = Add::{ add: custom_add }

pub let chosen : Int = op_add(1, 2, op=custom_add_ops)

pub fn use_offered_add() -> Int {
  chosen
}

pub fn answer() -> Unit ! Io {
  if use_offered_add() == 1 {
    Write::println!("chosen=1")
  } else {
    Write::println!("bad:chosen=1")
  }
}
