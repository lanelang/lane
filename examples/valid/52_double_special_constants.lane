module Examples.Valid.DoubleSpecialConstants

import Basic.Builtins.{ double_inf, double_nan, double_ninf }
import Basic.Io.{ println }
import Basic.Trait.Ops.*

pub fn answer() -> Unit ! Io {
  if double_inf > 1.0 {
    if double_ninf < 0.0 {
      if double_nan != double_nan {
        println("double constants ok")
      } else {
        println("nan equality failed")
      }
    } else {
      println("negative infinity comparison failed")
    }
  } else {
    println("infinity comparison failed")
  }
}
