module Examples.Valid08

import Basic.Io.{ println }
import Basic.Trait.Ops.*

pub struct Meter {
  value : Int
}

pub fn meter_equal(a : Meter, b : Meter) -> Bool {
  a.value == b.value
}

pub struct MeterOps {
  equal_impl : Equal[Meter]
}

pub offer meter_equal_ops : Equal[Meter] = Equal::{ equal: meter_equal }

pub let meter_ops : MeterOps = MeterOps::{ equal_impl: meter_equal_ops }

pub fn use_explicit_offer() -> Int {
  if Meter::{ value: 1 } == Meter::{ value: 1 } {
    1
  } else {
    0
  }
}

pub fn answer() -> Unit ! Io {
  if use_explicit_offer() == 1 {
    println("explicit equality=1")
  } else {
    println("bad:explicit equality=1")
  }
}
