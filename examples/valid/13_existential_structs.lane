module Examples.Valid13

import Basic.Io.{ println }

pub struct Hide {
  type T
  val : T
}

pub fn repack(h : Hide) -> Hide {
  {
    let Hide::{ T, val } = h
    Hide::{ T = T, val }
  }
}

pub let packed_int : Hide = Hide::{ T = Int, val: 42 }

pub let repacked_int : Hide = repack(packed_int)

pub fn answer() -> Unit ! Io {
  println("existential struct packed")
}
