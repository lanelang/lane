module Examples.Valid09

import Basic.Io.{ println }
import Basic.Ops.*

pub fn weird_add(a : Int, _b : Int) -> Int {
  a
}

pub fn use_weird_add(a : Int, b : Int) -> Int {
  let weird_add_ops : Add[Int] = Add::{ add: weird_add }
  op_add(a, b, op=weird_add_ops)
}

pub fn answer() -> Unit ! Io {
  if use_weird_add(40, 2) == 40 {
    println("weird_add=40")
  } else {
    println("bad:weird_add=40")
  }
}
