module Examples.Valid.EffectfulFunctionCalls

import Basic.Ops.*

import Basic.Io.{println}

effect Console {
  read() -> Int
}

fn read_int() -> Int ! Console {
  Console::read!()
}

fn call_read(f : () -> Int ! Console) -> Int ! Console {
  f()
}

pub let handled_value : Int = {
  handle call_read(read_int) with {
    Console::read(resume) => resume(42)
  } final value {
    value
  }
}

pub fn answer() -> Unit ! Io {
  if handled_value == 42 {
    println("42")
  } else {
    println("bad:42")
  }
}
