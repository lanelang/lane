module Examples.Valid.ModuleQualifiedAccess

import Stdlib.Ops.*

import Stdlib.Io.{Io, Write}

import Stdlib.Builtins

pub let sum_value : Int = Stdlib.Builtins.int_add(20, 22)

pub fn answer() -> Unit ! Io {
  if sum_value == 42 {
    Write::println!("42")
  } else {
    Write::println!("bad:42")
  }
}
