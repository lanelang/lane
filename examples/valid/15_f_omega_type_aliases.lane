// Valid: transparent type aliases, type-level lambdas, and higher-kinded
// type parameters normalize before value type checking and Buslane lowering.

module Examples.Valid15

import Basic.Io.{ println }

import Basic.Ops.*

pub struct Box[A] {
  value : A
}

pub type Id[A] = A

pub type ApplyInt[F : [Type] -> Type] = F[Int]

pub fn get(box : ApplyInt[Box]) -> Id[Int] {
  box.value
}

pub let aliased_value : Id[Int] = get(Box::{ value: 42 })

pub fn answer() -> Unit ! Io {
  if aliased_value == 42 {
    println("42")
  } else {
    println("bad:42")
  }
}
