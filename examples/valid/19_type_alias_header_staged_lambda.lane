// Valid: an alias header composes with a right-hand-side type-level lambda as
// the outer lambda layer.

module Examples.Valid19

import Basic.Ops.*
import Basic.Io.{ println }

pub struct Box[A] {
  value : A
}

pub type Mapper[F : [Type] -> Type] = type[A] => F[A]

pub type BoxInt = Mapper[Box][Int]

pub fn get(box : BoxInt) -> Int {
  box.value
}

pub let staged_value : Int = get(Box::{ value: 42 })

pub fn answer() -> Unit ! Io {
  if staged_value == 42 {
    println("42")
  } else {
    println("bad:42")
  }
}
