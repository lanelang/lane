import {
  "Milky2018/lanec/basic",
  "Milky2018/lanec/syntax",
  "moonbitlang/core/list",
}

rule(
  name: "moonyacc",
  command: "moon runwasm moonbitlang/yacc@0.7.14 --no-comments $input -o $output && moonfmt -w $output && moonfmt -w $output",
)

dev_build(
  rule: "moonyacc",
  input: "parser.mbty",
  output: "generated_parser.mbt",
)
