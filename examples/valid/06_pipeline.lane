module Examples.Valid06

import Basic.Io.{ println }

import Basic.Ops.*

pub fn add_three(a : Int, b : Int, c : Int) -> Int {
  a + b + c
}

pub fn pipeline_call(x : Int) -> Int {
  x |> add_three(1, 2)
}

pub fn pipeline_literal(x : Int) -> Int {
  x |> fn(value : Int) {
    value + 1
  }
}

pub fn answer() -> Unit ! Io {
  if pipeline_call(39) == 42 && pipeline_literal(41) == 42 {
    println("pipeline=42")
  } else {
    println("bad:pipeline=42")
  }
}
