module Examples.Valid.YieldEffect

import Basic.Io.{ println }

import Basic.Ops.*

pub enum IntList {
  nil()
  cons(Int, IntList)
}

pub fn sum(list : IntList) -> Int {
  match list {
    nil() => 0
    cons(head, tail) => head + sum(tail)
  }
}

effect Yield {
  emit(Int) -> Unit
}

fn produce() -> Int ! Yield {
  let _first : Unit = Yield::emit!(10)
  let _second : Unit = Yield::emit!(20)
  12
}

pub let emitted : IntList = {
  handle produce() with {
    Yield::emit(value, resume) => cons(value, resume(()))
  } final value {
    cons(value, IntList::nil())
  }
}

pub let emitted_sum : Int = sum(emitted)

pub fn answer() -> Unit ! Io {
  if emitted_sum == 42 {
    println("42")
  } else {
    println("bad:42")
  }
}
