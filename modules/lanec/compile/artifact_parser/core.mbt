///|
pub(all) enum ArtifactValue {
  Atom(String)
  Text(String)
} derive(Debug, Eq)

///|
pub(all) enum ArtifactEntry {
  Tag(String)
  Value(String, ArtifactValue)
  Block(String, String)
} derive(Debug, Eq)

///|
pub(all) struct ArtifactDocument {
  version : String
  kind : String
  entries : Array[ArtifactEntry]
} derive(Debug, Eq)

///|
pub fn parse_text(text : String) -> Result[ArtifactDocument, String] {
  let tokens = tokens_from_string(text) catch {
    ArtifactLexerError(message) =>
      return Err(
        artifact_error(
          "E5000", "invalid artifact text", message, "the artifact lexer could not tokenize this text artifact",
          "use an artifact emitted by the current `lane compile` or `lane link`",
        ),
      )
  }
  let yacc_tokens = tokens.map(fn(item) {
    let (token, loc) = item
    (token, loc, loc)
  })
  let document = artifact_document(yacc_tokens) catch {
    UnexpectedEndOfInput(_, _) =>
      return Err(
        artifact_error(
          "E5001", "unexpected end of artifact", "the artifact ended before the parser reached a closing `}`",
          "text artifacts must be complete `lane-artifact-text-v1 <kind> { ... }` documents",
          "regenerate the artifact instead of editing it by hand",
        ),
      )
    UnexpectedToken(_, _, _) =>
      return Err(
        artifact_error(
          "E5002", "unexpected artifact token", "the parser found a token that is not valid in this artifact section",
          "artifact text has a fixed field and block grammar", "check that this file is a Lane text artifact generated by this compiler",
        ),
      )
  }
  if document.version != "lane-artifact-text-v1" {
    Err(
      artifact_error(
        "E5003",
        "unsupported artifact text version",
        "found `\{document.version}`, expected `lane-artifact-text-v1`",
        "artifact text versions are compiler format contracts",
        "recompile or relink the artifact with the current Lane compiler",
      ),
    )
  } else if document.kind != "interface" &&
    document.kind != "object" &&
    document.kind != "program" {
    Err(
      artifact_error(
        "E5004",
        "unknown artifact kind",
        "found `\{document.kind}`, expected `interface`, `object`, or `program`",
        "the artifact kind determines which parser reads the payload",
        "pass an `.lmi`, `.lmo`, or `.lbp` text artifact produced by Lane",
      ),
    )
  } else {
    Ok(document)
  }
}

///|
fn artifact_error(
  code : String,
  title : String,
  label : String,
  note : String,
  help : String,
) -> String {
  "error[\{code}]: \{title}\n  = label: \{label}\n  = note: \{note}\n  = help: \{help}"
}
