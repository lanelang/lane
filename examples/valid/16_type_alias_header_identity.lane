// Valid: a single type alias parameter header desugars to a transparent
// type-level lambda.

module Examples.Valid16

import Basic.Trait.Ops.*
import Basic.Io.{ println }

pub type Id[A] = A

pub let identity_value : Id[Int] = 42

pub fn answer() -> Unit ! Io {
  if identity_value == 42 {
    println("42")
  } else {
    println("bad:42")
  }
}
