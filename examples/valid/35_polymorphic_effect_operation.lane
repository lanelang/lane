module Examples.Valid.PolymorphicEffectOperation

import Basic.Io.{println}

import Basic.Ops.*

effect Prompt {
  choose[A](A, A) -> A
}

fn choose_explicit() -> Int ! Prompt {
  Prompt::choose![Int](40, 41)
}

fn choose_inferred() -> Int ! Prompt {
  Prompt::choose!(1, 2)
}

pub let handled_value : Int = {
  let first : Int = handle choose_explicit() with {
    Prompt::choose[T](left, _right, resume) => resume(left)
  } final value {
    value
  }
  let second : Int = handle choose_inferred() with {
    Prompt::choose[T](_left, right, resume) => resume(right)
  } final value {
    value
  }
  first + second
}

pub fn answer() -> Unit ! Io {
  if handled_value == 42 {
    println("42")
  } else {
    println("bad:42")
  }
}
