module Examples.Valid.CoroutineScheduler

import Stdlib.Io.{Io, Write}

import Stdlib.Ops.*

effect Coroutine[E : Effect] {
  yield() -> Unit
  spawn[A](() -> A ! { Coroutine[E], E }) -> Unit
}

effect Log {
  log(Int) -> Unit
}

enum Task[E : Effect] {
  task[A](() -> A ! { Coroutine[E], E })
}

enum Runnable[E : Effect] {
  runnable(() -> Step[E] ! E)
}

enum Queue[E : Effect] {
  empty()
  node(Runnable[E], Queue[E])
}

enum Step[E : Effect] {
  done()
  yielded(() -> Step[E] ! E)
  spawned[A](() -> A ! { Coroutine[E], E }, () -> Step[E] ! E)
}

struct Scheduler[E : Effect] {
  queue : Queue[E]
}

struct RunResult {
  scheduler : Scheduler[Log]
  checksum : Int
}

fn[A, E : Effect] spawn(body : () -> A ! { Coroutine[E], E }) -> Unit ! Coroutine[E] {
  Coroutine[E]::spawn![A](body)
}

fn[E : Effect] yield() -> Unit ! Coroutine[E] {
  Coroutine[E]::yield!()
}

fn log(event : Int) -> Unit ! Log {
  Log::log!(event)
}

fn[E : Effect] enqueue(queue : Queue[E], item : Runnable[E]) -> Queue[E] {
  match queue {
    empty() => Queue[E]::node(item, Queue[E]::empty())
    node(head, tail) => Queue[E]::node(head, enqueue(tail, item))
  }
}

fn[E : Effect] with_queue(scheduler : Scheduler[E], queue : Queue[E]) -> Scheduler[E] {
  Scheduler[E]::{ queue }
}

fn[E : Effect] run_task(task_value : Task[E]) -> Step[E] ! E {
  match task_value {
    task[A](body) =>
      handle body() with {
        Coroutine[E]::yield(resume) => Step[E]::yielded(
          fn () -> Step[E] ! E {
            resume(())
          }
        )
        Coroutine[E]::spawn[B](body, resume) => Step[E]::spawned[B](
          body,
          fn () -> Step[E] ! E {
            resume(())
          }
        )
      } final value {
        Step[E]::done()
      }
  }
}

fn[E : Effect] run_queue(scheduler : Scheduler[E]) -> Scheduler[E] ! E {
  match scheduler.queue {
    empty() => scheduler
    node(runnable_step, rest) =>
      match runnable_step {
        runnable(run) => run_step(run(), with_queue(scheduler, rest))
      }
  }
}

fn[E : Effect] run_step(step : Step[E], scheduler : Scheduler[E]) -> Scheduler[E] ! E {
  match step {
    done() => run_queue(scheduler)
    yielded(resume) => run_queue(
      with_queue(scheduler, enqueue(scheduler.queue, Runnable[E]::runnable(resume)))
    )
    spawned[A](body, resume) => {
      let child : Runnable[E] =
        Runnable[E]::runnable(
          fn () -> Step[E] ! E {
            run_task(Task[E]::task[A](body))
          }
        )
      run_step(resume(), with_queue(scheduler, enqueue(scheduler.queue, child)))
    }
  }
}

fn collect_logs(scheduler : Scheduler[Log]) -> (Int) -> RunResult {
  handle run_queue(scheduler) with {
    Log::log(event, resume) => fn (checksum : Int) -> RunResult {
      resume(())(checksum * 100 + event)
    }
  } final scheduler {
    fn (checksum : Int) -> RunResult {
      RunResult::{ scheduler, checksum }
    }
  }
}

fn child() -> Bool ! { Coroutine[Log], Log } {
  let child_started : Unit = log(21)
  let child_yielded : Unit = yield[Log]()
  let child_resumed : Unit = log(22)
  true
}

fn parent() -> Int ! { Coroutine[Log], Log } {
  let parent_started : Unit = log(11)
  let child_spawned : Unit = spawn(child)
  let parent_after_spawn : Unit = log(12)
  let parent_yielded : Unit = yield[Log]()
  let parent_resumed : Unit = log(13)
  40
}

let result : RunResult =
  collect_logs(
    Scheduler[Log]::{
      queue: Queue[Log]::node(
        Runnable[Log]::runnable(
          fn () {
            run_task(Task[Log]::task[Int](parent))
          }
        ),
        Queue[Log]::empty()
      )
    }
  )(0)

pub let schedule_checksum : Int = result.checksum

pub fn answer() -> Unit ! Io {
  if schedule_checksum == 1112211322 {
    Write::println!("1112211322")
  } else {
    Write::println!("bad:1112211322")
  }
}
