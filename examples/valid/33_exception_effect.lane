module Examples.Valid.ExceptionEffect

import Basic.Trait.Ops.*
import Basic.Io.{ println }

effect Exception {
  raise(Int) -> Int
}

fn fail_with_answer() -> Int ! Exception {
  Exception::raise!(42)
}

pub let handled_value : Int = {
  handle fail_with_answer() with {
    Exception::raise(code, _resume) => code
  } final value {
    value
  }
}

pub fn answer() -> Unit ! Io {
  if handled_value == 42 {
    println("42")
  } else {
    println("bad:42")
  }
}
