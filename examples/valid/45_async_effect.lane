module Examples.Valid.AsyncEffect

import Basic.Io.{Io, Write}

import Basic.Ops.*

struct Future[A] {
  value : A
}

effect Async {
  ready[A](A) -> Future[A]
  spawn[A](() -> A ! Async) -> Future[A]
  await[A](Future[A]) -> A
}

fn[A] run_async(main : () -> A ! Async) -> A {
  handle main() with {
    ready[T](value, resume) => resume(Future[T]::{ value })
    spawn[T](body, resume) => {
      let value : T = run_async(body)
      resume(Future[T]::{ value })
    }
    await[T](future, resume) => resume(future.value)
  } final value {
    value
  }
}

fn program() -> Int ! Async {
  let first = ready!(20)
  let flag = ready!(true)
  let second =
    spawn![Int](
      fn () {
        if await!(flag) {
          await!(first) + 22
        } else {
          0
        }
      }
    )
  await!(second)
}

pub let async_result : Int = run_async(program)

pub fn answer() -> Unit ! Io {
  if async_result == 42 {
    Write::println!("42")
  } else {
    Write::println!("bad:42")
  }
}
