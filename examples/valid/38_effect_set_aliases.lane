module Examples.Valid.EffectSetAliases

import Basic.Io.{ println }
import Basic.Ops.*

effect Console {
  read() -> Int
}

effect Log {
  write(Int) -> Unit
}

type UI : Effect = { Console, Log }

type Task[E : Effect] : Effect = { Console, E }

fn read_and_log() -> Int ! UI {
  let value : Int = Console::read!()
  let _ignored : Unit = Log::write!(value)
  value
}

fn task_read() -> Int ! Task[Log] {
  read_and_log()
}

pub let handled_value : Int = {
  handle {
    handle task_read() with {
      Console::read(resume) => resume(40)
    } final value {
      value
    }
  } with {
    Log::write(_, resume) => resume(())
  } final value {
    value + 2
  }
}

pub fn answer() -> Unit ! Io {
  if handled_value == 42 {
    println("42")
  } else {
    println("bad:42")
  }
}
