// Valid: nested type-level binders may shadow alias header binders.

module Examples.Valid20

import Basic.Io.{ println }

pub type Shadow[_A] = type[A] => A

pub type BoolAlias = Shadow[Int][Bool]

pub let shadowed_value : BoolAlias = true

pub fn answer() -> Unit ! Io {
  if shadowed_value {
    println("true")
  } else {
    println("bad:true")
  }
}
