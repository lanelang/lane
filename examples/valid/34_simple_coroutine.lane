module Examples.Valid.SimpleCoroutine

import Basic.Io.{Io, Write}

import Basic.Ops.*

effect Coroutine {
  yield(Int) -> Int
}

pub enum CoroutineStep {
  done(Int)
  yielded(Int, (Int) -> CoroutineStep)
}

fn worker() -> Int ! Coroutine {
  let first : Int = Coroutine::yield!(1)
  let second : Int = Coroutine::yield!(first + 10)
  second + 100
}

fn start() -> CoroutineStep {
  handle worker() with {
    Coroutine::yield(value, resume) => yielded(
      value,
      fn (input : Int) -> CoroutineStep {
        resume(input)
      }
    )
  } final value {
    done(value)
  }
}

fn drive(step : CoroutineStep) -> Int {
  match step {
    done(value) => value
    yielded(value, resume) => value + drive(resume(value * 2))
  }
}

pub let coroutine_total : Int = drive(start())

pub fn answer() -> Unit ! Io {
  if coroutine_total == 137 {
    Write::println!("137")
  } else {
    Write::println!("bad:137")
  }
}
