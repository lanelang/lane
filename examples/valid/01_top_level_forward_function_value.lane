module Examples.Valid01

import Stdlib.Ops.*

import Stdlib.Io.{Io, Write}

pub fn read_stored_value() -> Int {
  stored_value
}

pub let stored_value : Int = 42

pub fn answer() -> Unit ! Io {
  if read_stored_value() == 42 {
    Write::println!("42")
  } else {
    Write::println!("bad:42")
  }
}
